{
    "manifest_version": 3,
    "name": "Script Cat",
    "version": "0.0.1",
    "description": "A script manager for Chrome",
    "background": {
        "service_worker": "src/service_worker.js"
    },
    "permissions": [
        "tabs",
        "alarms",
        "storage",
        "cookies",
        "offscreen",
        "scripting",
        "downloads",
        "activeTab",
        "webRequest",
        "userScripts",
        "contextMenus",
        "webNavigation",
        "notifications",
        "clipboardWrite",
        "unlimitedStorage",
        "declarativeNetRequest",
        "debugger"
    ],
    "action": {
        "default_popup": "src/popup.html"
    },
    "optional_permissions": ["background", "userScripts"],
    "host_permissions": ["<all_urls>"]
}